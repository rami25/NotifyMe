# ============================================================
# AL Actions API — environment variables
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# Fields marked REQUIRED will crash the server on boot if missing
# (see the `required()` check in src/config/env.js).
# ============================================================

# --- Server ---
PORT=8000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8100

# --- Database (PostgreSQL) --- REQUIRED
DATABASE_URL=postgres://al_actions:changeme@localhost:5432/al_actions

# --- Auth ---
# JWT_SECRET: REQUIRED. Signs/verifies this API's own session tokens
# (separate from Google's tokens). Use a long random string, e.g.:
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=12h

# GOOGLE_OAUTH_CLIENT_ID: REQUIRED. OAuth client ID from Google Cloud
# Console (Web application type), restricted to the airliquide.com
# Workspace. Must match the serverClientId used by the mobile app's
# GoogleAuth plugin. A placeholder value is fine until you test sign-in.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
ALLOWED_GOOGLE_DOMAIN=airliquide.com

# --- Email notifications (Gmail / SMTP) ---
# Optional at boot — sendEmail() just logs an error and no-ops if these
# aren't set, so the server won't crash without them.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notifications@airliquide.com
SMTP_APP_PASSWORD=replace-with-gmail-app-password
NOTIFICATIONS_FROM="AL Actions <notifications@airliquide.com>"
ADMIN_NOTIFICATION_EMAILS=admin1@airliquide.com,admin2@airliquide.com

# --- Push notifications (Firebase Cloud Messaging) ---
# Optional — sendPush() no-ops if this path isn't set or the file isn't
# found. Path to the Firebase service account JSON (never commit it).
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- Google Sheet ingestion (Navision / upstream intake) ---
# Optional — startSheetSyncPolling() logs "not configured" and skips
# polling if GOOGLE_SHEETS_ID or the service account path are missing.
GOOGLE_SHEETS_ID=replace-with-sheet-id
GOOGLE_SHEETS_RANGE=Actions!A2:H
# Separate service account from the OAuth client above — read-only
# access to the ingestion Sheet.
GOOGLE_SHEETS_SERVICE_ACCOUNT_PATH=./sheets-service-account.json
SHEET_SYNC_INTERVAL_MINUTES=5

# --- Overdue job ---
# Cron expression for the scheduled sweep that flips
# in_progress -> postponed past deadline. Default: every 15 minutes.
OVERDUE_JOB_CRON=*/15 * * * *
